generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum QuestionType {
  MCQ
  SHORT
  LONG
}

model User {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  phone      String?  @unique
  password   String
  role       Role
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  // Teacher exams
  exams      ExamPaper[]       @relation("TeacherExams")

  // Student attempts
  attempts   MockTestAttempt[]

  // Results as student
  studentResults Result[]      @relation("StudentResults")

  // Results as teacher
  teacherResults Result[]      @relation("TeacherResults")
}

model ExamPaper {
  id          String   @id @default(cuid())
  teacherId   String
  title       String
  subject     String
  difficulty  String
  description String?
  timeLimit   Int?
  createdAt   DateTime @default(now())

  // Teacher relation
  teacher     User     @relation("TeacherExams", fields: [teacherId], references: [id])

  // Questions
  questions   Question[]

  // Attempts
  attempts    MockTestAttempt[]

  // Results
  results     Result[]
}

model Question {
  id            String       @id @default(cuid())
  examPaperId   String
  type          QuestionType
  questionText  String
  answerKey     String
  marks         Int
  options       Json?

  examPaper     ExamPaper    @relation(fields: [examPaperId], references: [id])
}

model MockTestAttempt {
  id            String      @id @default(cuid())
  studentId     String
  examPaperId   String
  score         Float
  submittedAt   DateTime    @default(now())

  student       User        @relation(fields: [studentId], references: [id])
  examPaper     ExamPaper   @relation(fields: [examPaperId], references: [id])
}

model Result {
  id              String    @id @default(cuid())

  studentId       String
  teacherId       String
  examPaperId     String

  totalMarks      Float
  obtainedMarks   Float
  grade           String

  // Student relation
  student         User      @relation("StudentResults", fields: [studentId], references: [id])

  // Teacher relation
  teacher         User      @relation("TeacherResults", fields: [teacherId], references: [id])

  // Exam relation
  examPaper       ExamPaper @relation(fields: [examPaperId], references: [id])
  createdAt       DateTime  @default(now())
}