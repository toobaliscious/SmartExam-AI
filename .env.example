# Copy this file to .env and fill values before running locally or deploying.

# Database connection (Postgres/Neon/PlanetScale etc.)
DATABASE_URL=postgresql://user:password@localhost:5432/smartexam

# NextAuth secret (set to a long random string in production)
NEXTAUTH_SECRET=change_me_to_a_strong_secret

# OpenRouter or OpenAI / Gemini API key for AI integration
# For OpenRouter: set OPENROUTER_API_KEY
# For OpenAI: set OPENAI_API_KEY
# For Gemini: set GEMINI_API_KEY
OPENROUTER_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional: NEXTAUTH_URL for production (e.g., https://your-app.vercel.app)
NEXTAUTH_URL=http://localhost:3000

# Authentication secret (required in production)
NEXTAUTH_SECRET=
AUTH_SECRET=
